# SpectraX Backend (server/) configuration
# Copy to server/.env and adjust for your environment.

# Comma-separated list of allowed CORS origins.
# If unset, defaults to local dev origins (localhost:5173, 127.0.0.1:5173, localhost:3000).
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional shared-secret token for the Socket.IO handshake.
# When set, clients must connect with { auth: { token: <SOCKET_AUTH_TOKEN> } }.
# Leave empty to allow unauthenticated connections (local development only).
SOCKET_AUTH_TOKEN=

# Maximum frame events a single socket may send per second (default 60).
MAX_FRAMES_PER_SEC=60
